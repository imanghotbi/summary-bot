TELEGRAM_BOT_TOKEN=
TELEGRAM_BASE_URL=https://api.telegram.org/bot
TELEGRAM_BASE_FILE_URL=https://api.telegram.org/file/bot

# OpenAI-compatible endpoint settings
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_API_BASE_URL=https://api.openai.com/v1

# Optional outbound proxy for LLM requests, e.g. http://user:pass@host:port
OUTBOUND_PROXY_URL=

# Storage and app behavior
DATABASE_URL=sqlite+aiosqlite:///./data/telegram_summary_bot.db
RETENTION_DAYS=7
APP_TIMEZONE=Asia/Tehran
LOG_LEVEL=INFO
CLEANUP_INTERVAL_SECONDS=3600
SUMMARY_MAX_MESSAGES=1500
SUMMARY_MAX_INPUT_CHARS=120000
LLM_REQUEST_TIMEOUT_SECONDS=120
